---
import '../styles/global.css';
const { title = 'mycellm_', description = 'Distributed LLM inference.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#0a0a0a">
  <meta name="author" content="Michael Gifford-Santos">
  <link rel="author" href="/humans.txt">
  <meta property="og:site_name" content="mycellm">
  <meta property="og:type" content="website">
  <link rel="icon" type="image/svg+xml" href="/brand/logo-icon/svg/mycellm-red-logo-sans.svg">
  <title>{title}</title>
  <script defer src="https://analytics.zetaix.com/script.js" data-website-id="e70ee1fc-d684-497f-9f64-aa0dc624d74a"></script>
</head>
<body class="min-h-screen font-sans antialiased selection:bg-spore selection:text-black">
  <slot />
</body>
</html>
