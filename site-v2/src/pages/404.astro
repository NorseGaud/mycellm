---
import Page from '../layouts/Page.astro';
---
<Page title="mycellm_ — Page not found">
  <div class="flex-1 flex flex-col items-center justify-center px-4 py-20 text-center">
    <img src="/brand/logo-icon/svg/mycellm-purple-logo-sans.svg" alt="" class="w-16 h-16 mb-6 opacity-60">
    <h1 class="text-6xl sm:text-8xl font-extrabold text-white/10 font-mono mb-2">404</h1>
    <p class="text-lg text-gray-400 mb-1">This spore hasn't sprouted yet.</p>
    <p class="text-sm text-gray-600 mb-8">The page you're looking for doesn't exist or has moved.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/" class="bg-spore text-black font-semibold text-sm px-5 py-2 rounded-xl hover:bg-spore-glow transition-colors shadow-lg shadow-spore/20">Back to chat</a>
      <a href="/docs/quickstart/install" class="glass text-gray-300 text-sm px-5 py-2 rounded-xl hover:text-white hover:border-white/20 transition-colors">Read the docs</a>
    </div>
  </div>
</Page>
