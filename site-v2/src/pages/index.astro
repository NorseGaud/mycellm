---
import Page from '../layouts/Page.astro';
---
<Page title="mycellm_ — Free AI, powered by the crowd" description="Distributed LLM inference. Chat for free, powered by GPUs worldwide. No signup. Open source.">

  <!-- Hero -->
  <div class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-10 sm:py-16">
    <div class="w-full max-w-xl text-center space-y-6">
      <div class="flex justify-center mb-4 anim">
        <div class="relative w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28">
          <img id="heroShroom" src="/brand/logo-icon/svg/mycellm-red-logo-sans.svg" alt=""
               class="w-full h-full transition-all duration-700">
        </div>
      </div>

      <div class="anim anim-d1">
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white leading-tight">
          Free AI, <span class="text-spore-glow text-glow">powered by the crowd</span>
        </h1>
        <p class="text-gray-400 text-sm sm:text-base mt-3 max-w-md mx-auto leading-relaxed">
          Ask anything — served by GPUs worldwide on the mycellm distributed network. No signup.
        </p>
      </div>

      <div class="relative flex items-stretch anim anim-d2">
        <textarea id="heroInput" rows="2" placeholder="Ask anything..."
          class="w-full glass-green rounded-2xl rounded-r-none px-4 sm:px-5 py-3.5 sm:py-4 text-white text-base sm:text-lg resize-none transition-all focus:outline-none focus:border-spore/40 focus:shadow-[0_0_0_3px_rgba(34,197,94,0.08)]"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sessionStorage.setItem('mycellm_initial_prompt',this.value);location.href='/chat'}"></textarea>
        <button onclick="sessionStorage.setItem('mycellm_initial_prompt',document.getElementById('heroInput').value);location.href='/chat'"
          class="w-12 sm:w-14 bg-spore text-black rounded-2xl rounded-l-none flex items-center justify-center shadow-lg shadow-spore/20 hover:bg-spore-glow active:scale-95 transition-all shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>

      <p class="text-[10px] sm:text-[11px] text-gray-600 flex items-start justify-center space-x-1.5 anim anim-d3">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-gray-600 shrink-0 mt-px"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        <span>Prompts are processed by distributed GPU nodes. Don't share passwords or API keys.</span>
      </p>

      <div id="promptChips" class="flex flex-wrap justify-center gap-2 pt-1 anim anim-d4"></div>
    </div>
  </div>

  <!-- Why distributed -->
  <section class="border-t border-white/5 bg-[#050505]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-10 anim">
        Why <span class="text-compute">distributed</span> inference?
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <div class="glass rounded-xl p-5 space-y-2 hover-lift anim anim-d1">
          <div class="flex items-center space-x-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-spore shrink-0"><circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><path d="M12 8v4M8.5 17.5l2-4M15.5 17.5l-2-4"/></svg>
            <span class="text-spore font-semibold">No single point of failure</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            Models run across multiple peers. If one goes down, requests automatically route to another — no downtime.
          </p>
        </div>
        <div class="glass rounded-xl p-5 space-y-2 hover-lift anim anim-d2">
          <div class="flex items-center space-x-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-relay shrink-0"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/></svg>
            <span class="text-relay font-semibold">Your GPU, your credits</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            Contribute idle compute and earn credits. Spend them to run larger models across the network. A fair exchange.
          </p>
        </div>
        <div class="glass rounded-xl p-5 space-y-2 hover-lift anim anim-d3">
          <div class="flex items-center space-x-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ledger shrink-0"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
            <span class="text-ledger font-semibold">No vendor lock-in</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            Drop-in OpenAI-compatible API. Switch from any provider with one env var. Your tools, your choice.
          </p>
        </div>
        <div class="glass rounded-xl p-5 space-y-2 hover-lift anim anim-d4">
          <div class="flex items-center space-x-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-gray-300 shrink-0"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span class="text-gray-200 font-semibold">Private & federated</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            Run your own swarm or federate with trusted peers. Control membership, models, and data with cross-network routing.
          </p>
        </div>
        <div class="glass rounded-xl p-5 space-y-2 hover-lift anim anim-d5">
          <div class="flex items-center space-x-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-compute shrink-0"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            <span class="text-compute font-semibold">Open source</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            Apache 2.0 licensed. Audit the code, fork it, extend it. Every layer is transparent — no black boxes, no hidden costs.
          </p>
        </div>
        <div class="glass rounded-xl p-5 space-y-2 hover-lift anim anim-d6">
          <div class="flex items-center space-x-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-spore-glow shrink-0"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <span class="text-spore-glow font-semibold">Scales with community</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">
            Every new seeder makes the network faster and more capable. More contributors means more models and lower latency.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick start -->
  <section class="border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-2 anim">Get started in 60 seconds</h2>
      <p class="text-gray-500 text-center text-sm mb-8">pip, Docker, or one-liner — your choice.</p>

      <!-- Tabbed install card — all inline styles -->
      <div class="anim anim-d1" style="max-width:32rem;margin:0 auto;background:rgba(17,17,17,0.7);border:1px solid rgba(255,255,255,0.06);border-radius:0.75rem;overflow:hidden;backdrop-filter:blur(16px);">
        <div style="display:flex;border-bottom:1px solid rgba(255,255,255,0.05);">
          <button onclick="switchTab('curl')" data-tab="curl" style="flex:1;padding:0.625rem 1rem;font-family:'JetBrains Mono',monospace;font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.08em;background:none;border:none;border-bottom:2px solid #22C55E;color:#22C55E;cursor:pointer;transition:all 0.15s;-webkit-appearance:none;">Install</button>
          <button onclick="switchTab('pip')" data-tab="pip" style="flex:1;padding:0.625rem 1rem;font-family:'JetBrains Mono',monospace;font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.08em;background:none;border:none;border-bottom:2px solid transparent;color:#737373;cursor:pointer;transition:all 0.15s;-webkit-appearance:none;">pip</button>
          <button onclick="switchTab('docker')" data-tab="docker" style="flex:1;padding:0.625rem 1rem;font-family:'JetBrains Mono',monospace;font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.08em;background:none;border:none;border-bottom:2px solid transparent;color:#737373;cursor:pointer;transition:all 0.15s;-webkit-appearance:none;">Docker</button>
        </div>
        <div style="padding:1.25rem;position:relative;">
          <button onclick="copyInstall()" style="position:absolute;top:12px;right:12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:4px 8px;cursor:pointer;display:flex;align-items:center;gap:4px;color:#737373;font-size:10px;transition:all 0.15s;-webkit-appearance:none;" onmouseover="this.style.color='#22C55E';this.style.borderColor='rgba(34,197,94,0.3)'" onmouseout="this.style.color='#737373';this.style.borderColor='rgba(255,255,255,0.1)'">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span id="copyLabel"></span>
          </button>
          <div id="panel-curl">
            <div style="display:flex;gap:0;margin-bottom:0.75rem;">
              <button onclick="switchPlatform('unix')" data-plat="unix" style="padding:0.25rem 0.75rem;font-family:'JetBrains Mono',monospace;font-size:0.625rem;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:4px 0 0 4px;color:#22C55E;cursor:pointer;-webkit-appearance:none;">macOS / Linux</button>
              <button onclick="switchPlatform('win')" data-plat="win" style="padding:0.25rem 0.75rem;font-family:'JetBrains Mono',monospace;font-size:0.625rem;background:none;border:1px solid rgba(255,255,255,0.08);border-left:none;border-radius:0 4px 4px 0;color:#525252;cursor:pointer;-webkit-appearance:none;">Windows</button>
            </div>
            <div id="plat-unix" style="font-family:'JetBrains Mono',monospace;font-size:0.875rem;color:#4ADE80;word-break:break-all;">curl -fsSL mycellm.dev/install.sh | sh</div>
            <div id="plat-win" style="display:none;font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:#4ADE80;word-break:break-all;">irm mycellm.dev/install.ps1 | iex</div>
            <p style="font-size:0.75rem;color:#525252;margin-top:0.75rem;">Installs, initializes, prints next steps.</p>
          </div>
          <div id="panel-pip" style="display:none;font-family:'JetBrains Mono',monospace;font-size:0.875rem;">
            <div style="margin-bottom:6px;"><span style="color:#525252;">$</span> <span style="color:#4ADE80;">pip install mycellm</span></div>
            <div style="margin-bottom:6px;"><span style="color:#525252;">$</span> <span style="color:#4ADE80;">mycellm init</span></div>
            <div><span style="color:#525252;">$</span> <span style="color:#4ADE80;">mycellm serve</span></div>
          </div>
          <div id="panel-docker" style="display:none;font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#4ADE80;word-break:break-all;line-height:1.6;">
            docker run -d --name mycellm \<br>
            &nbsp;&nbsp;-p 8420:8420 \<br>
            &nbsp;&nbsp;-v mycellm-data:/data/mycellm \<br>
            &nbsp;&nbsp;ghcr.io/mycellm/mycellm
          </div>
        </div>
      </div>

      <script is:inline>
        const cmds = {
          curl: 'curl -fsSL https://mycellm.dev/install.sh | sh',
          'curl-win': 'irm https://mycellm.dev/install.ps1 | iex',
          pip: 'pip install mycellm && mycellm init && mycellm serve',
          docker: 'docker run -d --name mycellm -p 8420:8420 -v mycellm-data:/data/mycellm ghcr.io/mycellm/mycellm',
        };
        let activeTab = 'curl', activePlat = 'unix';
        function switchTab(tab) {
          activeTab = tab;
          document.querySelectorAll('[data-tab]').forEach(t => {
            const a = t.dataset.tab === tab;
            t.style.color = a ? '#22C55E' : '#737373';
            t.style.borderBottomColor = a ? '#22C55E' : 'transparent';
          });
          ['curl','pip','docker'].forEach(t => {
            const el = document.getElementById('panel-' + t);
            if (el) el.style.display = t === tab ? 'block' : 'none';
          });
          const cl = document.getElementById('copyLabel');
          if (cl) cl.textContent = '';
        }
        function switchPlatform(plat) {
          activePlat = plat;
          document.querySelectorAll('[data-plat]').forEach(b => {
            const a = b.dataset.plat === plat;
            b.style.background = a ? 'rgba(34,197,94,0.08)' : 'none';
            b.style.borderColor = a ? 'rgba(34,197,94,0.2)' : 'rgba(255,255,255,0.08)';
            b.style.color = a ? '#22C55E' : '#525252';
          });
          document.getElementById('plat-unix').style.display = plat === 'unix' ? 'block' : 'none';
          document.getElementById('plat-win').style.display = plat === 'win' ? 'block' : 'none';
        }
        function copyInstall() {
          const key = activeTab === 'curl' && activePlat === 'win' ? 'curl-win' : activeTab;
          navigator.clipboard.writeText(cmds[key]);
          const cl = document.getElementById('copyLabel');
          if (cl) { cl.textContent = 'Copied!'; setTimeout(() => cl.textContent = '', 2000); }
        }
      </script>

      <div class="text-center mt-8">
        <a href="/join" class="inline-block bg-spore text-black font-semibold text-sm px-6 py-2.5 rounded-xl hover:bg-spore-glow transition-colors shadow-lg shadow-spore/20">
          Join the network &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- OpenAI compatible -->
  <section class="border-t border-white/5 bg-[#050505]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-2 anim">Drop-in OpenAI replacement</h2>
      <p class="text-gray-500 text-center text-sm mb-8">Change one env var. Everything else stays the same.</p>

      <div class="max-w-lg mx-auto glass rounded-xl p-5 font-mono text-sm space-y-2 overflow-x-auto">
        <div class="text-gray-500 text-xs"># Point any OpenAI-compatible tool at mycellm</div>
        <div class="break-all text-xs sm:text-sm"><span class="text-gray-500">export </span><span class="text-relay">OPENAI_BASE_URL</span><span class="text-gray-400">=</span><span class="text-spore-glow">http://localhost:8420/v1</span></div>
        <div class="text-gray-500 mt-4 text-xs"># Works with:</div>
        <div class="text-gray-400 text-xs flex flex-wrap gap-x-1 gap-y-0.5">
          <span>Python SDK</span><span class="text-gray-600">&middot;</span>
          <span>LangChain</span><span class="text-gray-600">&middot;</span>
          <span>LlamaIndex</span><span class="text-gray-600">&middot;</span>
          <span>OpenCode</span><span class="text-gray-600">&middot;</span>
          <span>Claude Code</span><span class="text-gray-600">&middot;</span>
          <span>aider</span><span class="text-gray-600">&middot;</span>
          <span>Continue.dev</span>
        </div>
      </div>

      <div class="text-center mt-6">
        <a href="/integrations/openai/" class="text-spore text-sm hover:text-spore-glow transition-colors">View integration guides &rarr;</a>
      </div>
    </div>
  </section>

  <script>
    // ── Mushroom color cycling ──
    const colors = [
      'mycellm-red-logo-sans.svg',
      'mycellm-green-logo-sans.svg',
      'mycellm-blue-logo-sans.svg',
      'mycellm-gold-logo-sans.svg',
      'mycellm-purple-logo-sans.svg',
    ];
    let colorIdx = 0;
    const shroom = document.getElementById('heroShroom');
    if (shroom) {
      setInterval(() => {
        colorIdx = (colorIdx + 1) % colors.length;
        shroom.style.opacity = '0.3';
        setTimeout(() => {
          shroom.src = `/brand/logo-icon/svg/${colors[colorIdx]}`;
          shroom.style.opacity = '1';
        }, 350);
      }, 3000);
    }

    // ── Randomized diverse prompts ──
    const promptBanks = {
      tech: [
        'Explain distributed computing', 'How does BitTorrent work?',
        'Compare TCP and UDP', 'What is the CAP theorem?',
        'How do neural networks learn?', 'What is edge computing?',
        'Explain public key crypto', 'SQL vs NoSQL databases',
      ],
      science: [
        'How do black holes form?', 'Why is the sky blue?',
        'How does CRISPR work?', 'Explain quantum entanglement',
        'What causes tides?', 'How do vaccines work?',
        'What is dark matter?', 'How do plants make energy?',
      ],
      creative: [
        'Write a haiku about the sea', 'Tell a two-sentence horror story',
        'Describe a color to someone blind', 'Write a limerick about AI',
        'Invent a word and define it', 'Write a tiny fairy tale',
        'Describe rain poetically', 'Name a fictional planet',
      ],
      life: [
        'Best productivity tip?', 'How to learn a new language',
        'Explain stoicism simply', 'What makes a good leader?',
        'How to start meditating', 'Why is sleep important?',
        'Tips for public speaking', 'How to read more books',
      ],
    };
    const pick = (arr) => arr[Math.floor(Math.random() * arr.length)];
    const shuffled = [
      pick(promptBanks.tech), pick(promptBanks.science),
      pick(promptBanks.creative), pick(promptBanks.life),
    ].sort(() => Math.random() - 0.5).slice(0, 3);
    const chips = document.getElementById('promptChips');
    if (chips) {
      chips.innerHTML = shuffled.map(p =>
        `<button onclick="sessionStorage.setItem('mycellm_initial_prompt','${p.replace(/'/g, "\\'")}');location.href='/chat'"
          class="text-xs glass rounded-full px-3 py-1.5 text-gray-400 hover:text-white hover:border-white/20 transition-colors cursor-pointer">${p}</button>`
      ).join('');
    }
  </script>
</Page>
