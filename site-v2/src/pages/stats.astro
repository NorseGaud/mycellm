---
import Page from '../layouts/Page.astro';
---
<Page title="mycellm_ — Network Stats" description="Live stats for the mycellm distributed network.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 sm:py-10">
    <div class="mb-6">
      <h1 class="text-xl sm:text-2xl font-bold text-white">Network Stats</h1>
      <p class="text-sm text-gray-500 font-mono mt-1" id="networkName">Loading...</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
      <div class="glass rounded-xl p-4 text-center"><div class="text-2xl sm:text-3xl font-bold text-spore-glow font-mono" id="sNodes">-</div><div class="text-xs text-gray-400 mt-1">Nodes online</div></div>
      <div class="glass rounded-xl p-4 text-center"><div class="text-2xl sm:text-3xl font-bold text-compute font-mono" id="sTPS">-</div><div class="text-xs text-gray-400 mt-1">Tokens/sec</div></div>
      <div class="glass rounded-xl p-4 text-center"><div class="text-2xl sm:text-3xl font-bold text-relay font-mono" id="sModels">-</div><div class="text-xs text-gray-400 mt-1">Models</div></div>
      <div class="glass rounded-xl p-4 text-center"><div class="text-2xl sm:text-3xl font-bold text-ledger font-mono" id="sVRAM">-</div><div class="text-xs text-gray-400 mt-1">VRAM (GB)</div></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-6">
      <div class="glass rounded-xl p-4 sm:p-5">
        <h3 class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3">Activity</h3>
        <div class="grid grid-cols-3 gap-3 text-center">
          <div><div class="text-xl font-bold font-mono text-spore-glow" id="sReqs">0</div><div class="text-[11px] text-gray-500">Requests</div></div>
          <div><div class="text-xl font-bold font-mono text-spore-glow" id="sToks">0</div><div class="text-[11px] text-gray-500">Tokens</div></div>
          <div><div class="text-xl font-bold font-mono text-spore-glow" id="sRPM">0</div><div class="text-[11px] text-gray-500">Req/min</div></div>
        </div>
      </div>
      <div class="glass rounded-xl p-4 sm:p-5">
        <h3 class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3">Uptime</h3>
        <div class="text-2xl font-bold font-mono text-spore-glow" id="sUp">-</div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-6">
      <div class="glass rounded-xl p-4 sm:p-5">
        <h3 class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3">Top Contributors</h3>
        <div id="sContrib" class="space-y-1 font-mono text-sm"><div class="text-gray-600 text-xs">Loading...</div></div>
      </div>
      <div class="glass rounded-xl p-4 sm:p-5">
        <h3 class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3">Models</h3>
        <div id="sModelList" class="space-y-2"><span class="text-gray-600 text-xs">Loading...</span></div>
      </div>
    </div>

    <div class="glass-green rounded-2xl p-6 text-center">
      <h2 class="text-xl font-bold text-spore-glow text-glow mb-2">Join the Network</h2>
      <p class="text-gray-400 text-sm mb-4">Contribute your GPU and earn credits.</p>
      <a href="/join" class="inline-block bg-spore text-black font-semibold text-sm px-6 py-2.5 rounded-xl hover:bg-spore-glow transition-colors shadow-lg shadow-spore/20">Get Started &rarr;</a>
    </div>
  </div>

  <script is:inline>
    const API = window.location.hostname === 'localhost' || window.location.hostname.endsWith('.lan')
      ? `${window.location.protocol}//${window.location.hostname}:8420` : 'https://api.mycellm.dev';
    function fmt(n){if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return n.toString()}
    function fmtUp(s){const d=Math.floor(s/86400),h=Math.floor((s%86400)/3600),m=Math.floor((s%3600)/60);if(d>0)return`${d}d ${h}h`;if(h>0)return`${h}h ${m}m`;return`${m}m`}
    async function poll(){try{const r=await fetch(`${API}/v1/node/public/stats`);if(!r.ok)return;const d=await r.json();
      document.getElementById('networkName').textContent=d.network_name;
      document.getElementById('sNodes').textContent=d.nodes.online;
      document.getElementById('sTPS').textContent=d.compute.total_tps.toFixed(1);
      document.getElementById('sModels').textContent=d.models.unique;
      document.getElementById('sVRAM').textContent=d.compute.total_vram_gb.toFixed(1);
      document.getElementById('sReqs').textContent=fmt(d.activity.total_requests);
      document.getElementById('sToks').textContent=fmt(d.activity.total_tokens);
      document.getElementById('sRPM').textContent=d.activity.requests_per_min.toFixed(1);
      document.getElementById('sUp').textContent=fmtUp(d.uptime_seconds);
      const ce=document.getElementById('sContrib');
      ce.innerHTML=d.top_contributors?.length?d.top_contributors.map((c,i)=>`<div class="flex justify-between py-0.5 ${i<3?'text-spore-glow':'text-gray-400'}"><span>${i+1}. ${c.name}</span><span class="text-xs">${c.tps?c.tps.toFixed(1)+' T/s':c.models+' models'}</span></div>`).join(''):'<div class="text-gray-600 text-xs">No contributors yet</div>';
      const ml=document.getElementById('sModelList');const t=d.models?.by_tier||{};let h='';
      for(const[k,l]of[['tier1','Tier 1'],['tier2','Tier 2'],['tier3','Tier 3']]){const m=t[k]||[];if(m.length){const c=k==='tier1'?'text-spore':k==='tier2'?'text-relay':'text-ledger';h+=`<div class="${c} text-xs font-medium">${l}</div><div class="flex flex-wrap gap-1.5 mb-2">${m.map(n=>`<span class="px-2 py-0.5 glass rounded text-xs text-gray-300 font-mono">${n}</span>`).join('')}</div>`;}}
      ml.innerHTML=h||'<span class="text-gray-600 text-xs">No models</span>';
    }catch{}}
    poll();setInterval(poll,10000);
  </script>
</Page>
