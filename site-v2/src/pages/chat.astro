---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import ParticleCanvas from '../components/ParticleCanvas.astro';
---
<Base title="mycellm_ — Chat" description="Chat with the mycellm distributed network.">
  <ParticleCanvas />

  <!-- Fixed header — same as all pages -->
  <div style="position:fixed;top:0;left:0;right:0;z-index:40;">
    <Header currentPath="/chat" />
  </div>

  <!-- Messages area — between fixed header and fixed input -->
  <div id="chatMessages" style="position:fixed;top:3rem;left:0;right:0;bottom:4rem;overflow-y:auto;overflow-x:hidden;z-index:10;">
    <div style="max-width:48rem;margin:0 auto;padding:0.75rem;">
      <!-- Privacy notice -->
      <div id="privacyNotice" style="background:rgba(17,17,17,0.7);border:1px solid rgba(255,255,255,0.06);border-radius:0.5rem;padding:0.5rem 0.75rem;margin-bottom:0.75rem;display:flex;align-items:center;justify-content:space-between;font-size:11px;color:#737373;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#737373" stroke-width="2" style="flex-shrink:0;"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
          <span>Prompts are processed by distributed GPU nodes. Don't share passwords or API keys.</span>
        </div>
        <button onclick="this.parentElement.remove()" style="background:none;border:none;color:#525252;cursor:pointer;padding:0 4px;font-size:16px;line-height:1;-webkit-appearance:none;">×</button>
      </div>
      <div id="chatMsgInner" style="display:flex;flex-direction:column;gap:0.75rem;"></div>
    </div>
  </div>

  <!-- Fixed input bar at bottom -->
  <div style="position:fixed;bottom:0;left:0;right:0;z-index:40;border-top:1px solid rgba(255,255,255,0.05);background:rgba(10,10,10,0.9);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);">
    <div style="max-width:48rem;margin:0 auto;padding:0.5rem 0.75rem;display:flex;box-sizing:border-box;">
      <textarea id="chatInput" rows="1" placeholder="Type a message..."
        style="flex:1;min-width:0;background:rgba(17,17,17,0.7);border:1px solid rgba(255,255,255,0.06);border-right:none;border-radius:0.75rem 0 0 0.75rem;padding:0.75rem 1rem;color:white;font-size:16px;resize:none;outline:none;box-sizing:border-box;font-family:inherit;"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMessage()}"
        oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
      <button id="sendBtn" onclick="sendMessage()"
        style="width:44px;flex-shrink:0;background:#22C55E;color:black;border:none;border-radius:0 0.75rem 0.75rem 0;display:flex;align-items:center;justify-content:center;cursor:pointer;-webkit-appearance:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/styles/github-dark-dimmed.min.css">
  <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/highlight.min.js"></script>

  <script is:inline>
    const API_BASE = window.location.hostname === 'localhost' || window.location.hostname.endsWith('.lan')
      ? `${window.location.protocol}//${window.location.hostname}:8420` : 'https://api.mycellm.dev';
    let messages = [], isStreaming = false;

    if (typeof marked !== 'undefined') marked.setOptions({ highlight: (c,l) => typeof hljs!=='undefined'&&l&&hljs.getLanguage(l)?hljs.highlight(c,{language:l}).value:typeof hljs!=='undefined'?hljs.highlightAuto(c).value:c, breaks:true, gfm:true });
    function renderMd(t) { try { return marked.parse(t||'') } catch { return (t||'').replace(/</g,'&lt;') } }
    function escHtml(s) { const d=document.createElement('div'); d.textContent=s; return d.innerHTML }

    function scrollToBottom() {
      const el = document.getElementById('chatMessages');
      if (el) el.scrollTop = el.scrollHeight;
    }

    function addMsg(role, content) {
      messages.push({role, content});
      const c = document.getElementById('chatMsgInner'), d = document.createElement('div');
      const u = role==='user', dots = !u && !content;
      d.style.cssText = `display:flex;${u?'justify-content:flex-end':'justify-content:flex-start'}`;
      d.innerHTML = `<div style="max-width:85%;"><div style="background:${u?'rgba(34,197,94,0.04)':'rgba(17,17,17,0.7)'};border:1px solid ${u?'rgba(34,197,94,0.12)':'rgba(255,255,255,0.06)'};border-radius:1rem ${u?'1rem 0.25rem 1rem':'0.25rem 1rem 1rem'};padding:0.625rem 0.875rem;font-size:0.875rem;line-height:1.5;color:${u?'white':'#D4D4D4'};word-break:break-word;overflow-wrap:anywhere;"><div class="msg-content ${u?'':'msg-md'}">${dots?'<span style="display:inline-flex;align-items:center;gap:4px;"><span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;"></span><span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;"></span><span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;"></span></span>':(u?escHtml(content):renderMd(content))}</div></div>${u?'':'<div class="msg-attr" style="font-size:10px;color:#525252;margin-top:4px;margin-left:4px;font-family:JetBrains Mono,monospace;"></div>'}</div>`;
      c.appendChild(d);
      scrollToBottom();
      return { contentEl: d.querySelector('.msg-content'), attrEl: d.querySelector('.msg-attr') };
    }

    const MAX_RETRIES = 5;
    const RETRY_DELAYS = [2, 4, 8, 15, 30]; // seconds, exponential backoff

    function showError(contentEl, attrEl, message, retryText) {
      contentEl.innerHTML = `<div style="display:flex;align-items:center;gap:8px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" style="flex-shrink:0;"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        <span style="color:#A3A3A3;">${escHtml(message)}</span>
      </div>`;
      if (retryText && attrEl) {
        attrEl.innerHTML = `<button onclick="document.getElementById('chatInput').value='${escHtml(retryText).replace(/'/g,"\\'")}';this.closest('[style]').remove();messages.pop();messages.pop();sendMessage()" style="background:none;border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:2px 10px;cursor:pointer;color:#737373;font-size:10px;font-family:JetBrains Mono,monospace;-webkit-appearance:none;">Retry</button>`;
      }
    }

    function showRetryStatus(contentEl, attempt, delay) {
      contentEl.innerHTML = `<div style="display:flex;align-items:center;gap:8px;color:#737373;font-size:12px;">
        <span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#EAB308;"></span>
        <span>Models busy — retrying in <span id="retryCountdown">${delay}</span>s (attempt ${attempt}/${MAX_RETRIES})</span>
      </div>`;
    }

    function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

    async function tryFetch(msgPayload) {
      return fetch(`${API_BASE}/v1/public/chat/completions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(msgPayload),
      });
    }

    async function sendMessage() {
      if (isStreaming) return;
      const input = document.getElementById('chatInput'), text = input.value.trim();
      if (!text) return;
      input.value = ''; input.style.height = 'auto';
      addMsg('user', text);
      const {contentEl, attrEl} = addMsg('assistant', '');
      isStreaming = true;
      const startTime = Date.now();
      const msgPayload = { messages: messages.slice(0,-1).map(m=>({role:m.role,content:m.content})), stream: true };

      let resp, attempt = 0;
      while (attempt <= MAX_RETRIES) {
        try {
          resp = await tryFetch(msgPayload);

          // Retryable errors: 429 (rate limit) and 503 (busy)
          if ((resp.status === 429 || resp.status === 503) && attempt < MAX_RETRIES) {
            attempt++;
            const delay = RETRY_DELAYS[Math.min(attempt - 1, RETRY_DELAYS.length - 1)];
            showRetryStatus(contentEl, attempt, delay);
            // Countdown timer
            for (let s = delay; s > 0; s--) {
              const el = document.getElementById('retryCountdown');
              if (el) el.textContent = s;
              await sleep(1000);
            }
            continue;
          }

          if (!resp.ok) {
            const e = await resp.json().catch(()=>({}));
            const msg = e.error?.message || `Error: ${resp.status}`;
            if (resp.status === 429) {
              showError(contentEl, attrEl, 'Rate limit reached — please try again later.', text);
            } else if (resp.status === 503) {
              showError(contentEl, attrEl, 'All models are busy. Retries exhausted — please try again shortly.', text);
            } else {
              showError(contentEl, attrEl, msg, text);
            }
            isStreaming = false; return;
          }
          break; // success — proceed to streaming
        } catch(e) {
          if (attempt < MAX_RETRIES && !(e.name === 'TypeError' && e.message.includes('fetch'))) {
            attempt++;
            const delay = RETRY_DELAYS[Math.min(attempt - 1, RETRY_DELAYS.length - 1)];
            showRetryStatus(contentEl, attempt, delay);
            for (let s = delay; s > 0; s--) {
              const el = document.getElementById('retryCountdown');
              if (el) el.textContent = s;
              await sleep(1000);
            }
            continue;
          }
          if (e.name === 'TypeError' && e.message.includes('fetch')) {
            showError(contentEl, attrEl, 'Cannot reach the network. Check your connection.', text);
          } else {
            showError(contentEl, attrEl, 'Connection lost. Please try again.', text);
          }
          isStreaming = false; return;
        }
      }

      // Stream the response
      try {
        contentEl.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px;color:#737373;font-size:12px;"><span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;"></span><span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;"></span><span class="typing-dot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;"></span></span>';
        let fullText='',model='',nodeId='',sLat=0,gotFirstToken=false;
        const reader=resp.body.getReader(), dec=new TextDecoder(); let buf='';
        while(true) { const{done,value}=await reader.read(); if(done)break; buf+=dec.decode(value,{stream:true}); const lines=buf.split('\n'); buf=lines.pop();
          for(const line of lines) { if(!line.startsWith('data: '))continue; const p=line.slice(6).trim(); if(p==='[DONE]')break;
            try { const ch=JSON.parse(p); model=ch.model||model; if(ch.mycellm){nodeId=ch.mycellm.node||nodeId;if(ch.mycellm.latency_ms)sLat=ch.mycellm.latency_ms;if(attrEl&&nodeId&&!attrEl.textContent)attrEl.textContent=`${model} via node ${nodeId}`}
              const delta=ch.choices?.[0]?.delta?.content||''; if(delta){if(!gotFirstToken){gotFirstToken=true;contentEl.innerHTML=''}fullText+=delta;contentEl.innerHTML=renderMd(fullText);scrollToBottom()}
            } catch{} } }
        if (!fullText) {
          showError(contentEl, attrEl, 'No response received. The network may be busy.', text);
        } else {
          messages[messages.length-1].content=fullText;
          if(attrEl) attrEl.innerHTML=`<span style="color:#525252;">${model}</span> via node ${nodeId||'local'} · ${sLat||(Date.now()-startTime)}ms`;
        }
      } catch(e) {
        showError(contentEl, attrEl, 'Connection lost during response. Please try again.', text);
      }
      isStreaming = false;
    }

    // Initial prompt from homepage
    const ip = sessionStorage.getItem('mycellm_initial_prompt');
    if (ip) { sessionStorage.removeItem('mycellm_initial_prompt'); document.getElementById('chatInput').value=ip; setTimeout(sendMessage,200) }
    else document.getElementById('chatInput')?.focus();
  </script>

  <style>
    .msg-md p { margin:0.4em 0 } .msg-md p:first-child { margin-top:0 } .msg-md p:last-child { margin-bottom:0 }
    .msg-md pre { margin:0.5em 0; border-radius:0.5rem; overflow-x:auto; padding:0.75rem; background:rgba(0,0,0,0.5)!important; font-size:0.8rem; max-width:100% }
    .msg-md code { font-family:'JetBrains Mono',monospace; font-size:0.85em }
    .msg-md :not(pre)>code { background:rgba(255,255,255,0.08); padding:0.15em 0.35em; border-radius:0.25rem }
    .msg-md strong { color:#fff }
    @keyframes dot-pulse { 0%,80%,100%{opacity:0.3;transform:scale(0.8)} 40%{opacity:1;transform:scale(1)} }
    .typing-dot { animation:dot-pulse 1.4s ease-in-out infinite }
    .typing-dot:nth-child(2) { animation-delay:0.16s }
    .typing-dot:nth-child(3) { animation-delay:0.32s }
  </style>
</Base>
