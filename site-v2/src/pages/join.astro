---
import Page from '../layouts/Page.astro';
---
<Page title="mycellm_ — Join" description="Join the mycellm distributed LLM inference network.">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 sm:py-16">
    <div class="text-center mb-10">
      <img src="/brand/logo-icon/svg/mycellm-red-logo-sans.svg" alt="" class="w-14 h-14 mx-auto mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-spore-glow text-glow mb-2">Join mycellm</h1>
      <p class="text-gray-400 text-sm sm:text-base">Contribute your GPU to the distributed network.</p>
    </div>

    <div class="space-y-4">
      <div class="glass rounded-xl p-4 sm:p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-spore/10 border border-spore/20 text-spore flex items-center justify-center font-bold text-sm shrink-0">1</span>
          <h3 class="font-semibold">Install</h3>
        </div>
        <div class="glass rounded-lg p-3 font-mono text-sm"><span class="text-gray-600">$</span> <span class="text-spore-glow">pip install mycellm</span></div>
        <p class="text-xs text-gray-500 mt-2">Python 3.11+. macOS, Linux, Windows (WSL).</p>
      </div>

      <div class="glass rounded-xl p-4 sm:p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-spore/10 border border-spore/20 text-spore flex items-center justify-center font-bold text-sm shrink-0">2</span>
          <h3 class="font-semibold">Initialize</h3>
        </div>
        <div class="glass rounded-lg p-3 font-mono text-sm"><span class="text-gray-600">$</span> <span class="text-spore-glow">mycellm init</span></div>
        <p class="text-xs text-gray-500 mt-2">Creates identity, joins public network. Auto-approved.</p>
      </div>

      <div class="glass rounded-xl p-4 sm:p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-spore/10 border border-spore/20 text-spore flex items-center justify-center font-bold text-sm shrink-0">3</span>
          <h3 class="font-semibold">Serve</h3>
        </div>
        <div class="glass rounded-lg p-3 font-mono text-sm space-y-1">
          <div><span class="text-gray-600">$</span> <span class="text-spore-glow">mycellm serve</span></div>
          <div class="text-gray-600 text-xs"># Or as a service:</div>
          <div><span class="text-gray-600">$</span> <span class="text-spore-glow">mycellm serve --install-service</span></div>
        </div>
        <p class="text-xs text-gray-500 mt-2">Your node appears on <a href="/stats" class="text-spore">network stats</a> within 60 seconds.</p>
      </div>

      <div class="glass rounded-xl p-4 sm:p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-relay/10 border border-relay/20 text-relay flex items-center justify-center font-bold text-sm shrink-0">D</span>
          <h3 class="font-semibold">Docker</h3>
        </div>
        <div class="glass rounded-lg p-3 font-mono text-xs sm:text-sm text-spore-glow break-all">
          docker run -d --name mycellm -p 8420:8420 -v mycellm-data:/data/mycellm ghcr.io/mycellm/mycellm
        </div>
      </div>

      <div class="glass rounded-xl p-4 sm:p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-poison/10 border border-poison/20 text-gray-300 flex items-center justify-center font-bold text-sm shrink-0">#</span>
          <h3 class="font-semibold">One-liner</h3>
        </div>
        <div class="glass rounded-lg p-3 font-mono text-sm text-spore-glow break-all">curl -fsSL mycellm.dev/install.sh | sh</div>
      </div>
    </div>
  </div>
</Page>
