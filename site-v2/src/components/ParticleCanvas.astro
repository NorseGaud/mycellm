<canvas id="networkCanvas" class="fixed inset-0 z-0 opacity-[0.35] pointer-events-none"></canvas>
<script>
const c=document.getElementById('networkCanvas');if(c){const x=c.getContext('2d');let W,H;const P=[];const N=Math.min(Math.floor(window.innerWidth/16),90),D=150;
function r(){W=c.width=window.innerWidth;H=c.height=window.innerHeight}
class Pt{constructor(){this.x=Math.random()*W;this.y=Math.random()*H;this.vx=(Math.random()-.5)*.35;this.vy=(Math.random()-.5)*.35;this.r=Math.random()*2+.5;this.p=Math.random()*Math.PI*2}step(){this.x+=this.vx;this.y+=this.vy;if(this.x<0||this.x>W)this.vx*=-1;if(this.y<0||this.y>H)this.vy*=-1;this.p+=.012}draw(){x.beginPath();x.arc(this.x,this.y,Math.max(.2,this.r+Math.sin(this.p)*.6),0,Math.PI*2);x.fillStyle=`rgba(74,222,128,${.5+Math.sin(this.p)*.3})`;x.fill()}}
function init(){for(let i=0;i<N;i++)P.push(new Pt())}
function loop(){x.clearRect(0,0,W,H);for(let i=0;i<P.length;i++){P[i].step();P[i].draw();for(let j=i+1;j<P.length;j++){const dx=P[i].x-P[j].x,dy=P[i].y-P[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<D){x.beginPath();x.moveTo(P[i].x,P[i].y);x.lineTo(P[j].x,P[j].y);x.strokeStyle=`rgba(74,222,128,${(1-d/D)*.25})`;x.lineWidth=1;x.stroke()}}}requestAnimationFrame(loop)}
window.addEventListener('resize',r);r();init();loop()}
</script>
