---
const { currentPath = '' } = Astro.props;
const links = [
  { href: '/', label: 'Chat', match: ['/', '/chat'] },
  { href: '/stats', label: 'Stats', match: ['/stats'] },
  { href: '/join', label: 'Join', match: ['/join'] },
  { href: '/docs/quickstart/install', label: 'Docs', match: ['/docs'] },
  { href: '/about', label: 'About', match: ['/about'] },
];
---
<header style="position:sticky;top:0;z-index:30;border-bottom:1px solid rgba(255,255,255,0.05);background:rgba(10,10,10,0.8);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);">
  <div style="max-width:64rem;margin:0 auto;padding:0 1rem;height:3rem;display:flex;align-items:center;justify-content:space-between;">
    <a href="/" style="flex-shrink:0;">
      <img src="/brand/header/svg/mycellm-h-R.svg" alt="mycellm" style="height:1.25rem;">
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex" style="align-items:center;gap:1rem;font-family:'JetBrains Mono',monospace;font-size:0.875rem;">
      {links.map(l => {
        const active = l.match.some(m => currentPath === m || (m !== '/' && currentPath.startsWith(m)));
        return <a href={l.href}
          style={`padding:0.25rem 0.5rem;border-radius:0.25rem;transition:color 0.15s;color:${active ? '#22C55E' : '#737373'};`}
          onmouseover={active ? undefined : "this.style.color='#22C55E'"}
          onmouseout={active ? undefined : "this.style.color='#737373'"}
        >{l.label}</a>
      })}
    </nav>

    <div style="display:flex;align-items:center;gap:0.75rem;flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:0.375rem;font-family:'JetBrains Mono',monospace;font-size:0.6875rem;color:#737373;">
        <span id="hdrDot" style="width:6px;height:6px;border-radius:50%;background:#22C55E;animation:pulse 2s infinite;"></span>
        <span id="hdrNodes">-</span><span class="hidden sm:inline">&nbsp;nodes</span>
      </div>
      <a href="https://github.com/mycellm/mycellm" target="_blank" rel="noopener" class="hidden sm:block" style="color:#525252;" title="Source">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <!-- Mobile menu button — inline styles only, no class interference -->
      <button id="menuToggle" class="sm:hidden" style="background:none;border:none;padding:8px;cursor:pointer;-webkit-appearance:none;appearance:none;outline:none;" aria-label="Menu">
        <div id="menuOpen">
          <div style="width:20px;height:2px;background:#737373;margin-bottom:5px;"></div>
          <div style="width:20px;height:2px;background:#737373;margin-bottom:5px;"></div>
          <div style="width:20px;height:2px;background:#737373;"></div>
        </div>
        <div id="menuClose" style="display:none;color:#737373;font-size:20px;line-height:1;width:20px;text-align:center;">×</div>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobileNav" style="display:none;border-top:1px solid rgba(255,255,255,0.05);background:rgba(10,10,10,0.95);backdrop-filter:blur(16px);">
    <div style="max-width:64rem;margin:0 auto;padding:0.75rem 1rem;display:flex;flex-direction:column;gap:0.25rem;">
      {links.map(l => {
        const active = l.match.some(m => currentPath === m || (m !== '/' && currentPath.startsWith(m)));
        return <a href={l.href}
          style={`padding:0.5rem 0.75rem;border-radius:0.5rem;font-family:'JetBrains Mono',monospace;font-size:0.875rem;color:${active ? '#22C55E' : '#A3A3A3'};${active ? 'background:rgba(34,197,94,0.05);' : ''}`}
          onmouseover={active ? undefined : "this.style.color='#22C55E'"}
          onmouseout={active ? undefined : "this.style.color='#A3A3A3'"}
        >{l.label}</a>
      })}
      <a href="https://github.com/mycellm/mycellm" target="_blank" rel="noopener"
         style="padding:0.5rem 0.75rem;border-radius:0.5rem;font-family:'JetBrains Mono',monospace;font-size:0.875rem;color:#A3A3A3;display:flex;align-items:center;gap:0.5rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<style>
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const nav = document.getElementById('mobileNav');
  const openIcon = document.getElementById('menuOpen');
  const closeIcon = document.getElementById('menuClose');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isHidden = nav.style.display === 'none' || nav.style.display === '';
      nav.style.display = isHidden ? 'block' : 'none';
      if (openIcon) openIcon.style.display = isHidden ? 'none' : 'block';
      if (closeIcon) closeIcon.style.display = isHidden ? 'block' : 'none';
    });
  }

  const API = window.location.hostname === 'localhost' || window.location.hostname.endsWith('.lan')
    ? `${window.location.protocol}//${window.location.hostname}:8420` : 'https://api.mycellm.dev';
  async function hdrStats() {
    try { const r = await fetch(`${API}/v1/node/public/stats`); if(!r.ok)return; const d=await r.json();
      const n=document.getElementById('hdrNodes'); if(n) n.textContent=d.nodes?.online||'-';
    } catch { const dot=document.getElementById('hdrDot'); if(dot) dot.style.background='#525252'; }
  }
  hdrStats(); setInterval(hdrStats,15000);
</script>
