# mycellm public bootstrap node — production config
# Copy to docker/.env.prod on the deployment host

# Dashboard admin key — required to access /v1/* admin endpoints
# Public endpoints (/v1/public/*, /health, /metrics) are always open
MYCELLM_API_KEY=change_me

# Node identity
MYCELLM_NODE_NAME=my_node

# Bootstrap peers (empty — this IS the bootstrap)
MYCELLM_BOOTSTRAP_PEERS=
